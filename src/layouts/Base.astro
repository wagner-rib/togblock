---
import '@fontsource/baloo-2/500.css';
import '@fontsource/baloo-2/600.css';
import '@fontsource/baloo-2/700.css';
import '@fontsource/baloo-2/800.css';
import '@fontsource/nunito/400.css';
import '@fontsource/nunito/400-italic.css';
import '@fontsource/nunito/600.css';
import '@fontsource/nunito/700.css';
import '@fontsource/nunito/800.css';
import '../styles/tokens.css';
import '../styles/vibes.css';
import '../styles/global.css';
import '../styles/builder.css';
import '../styles/pages.css';
import '../styles/product.css';
import '../styles/home.css';

interface Props {
  title: string;
  description: string;
  currentPage?: string;
  ogImage?: string;
}

const { title, description, currentPage = '/', ogImage = '/og.png' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const navItems = [
  { label: 'Products',     href: '/products' },
  { label: 'How it works', href: '/#how' },
  { label: 'About',        href: '/about' },
  { label: 'FAQ',          href: '/faq' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:image"       content={new URL(ogImage, Astro.site)} />
  <meta property="og:locale"      content="en_IE" />
  <meta property="og:site_name"   content="TógBlocks" />

  <!-- Twitter card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={new URL(ogImage, Astro.site)} />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <!-- Theme colour -->
  <meta name="theme-color" content="#1D4ED8" />

  <!-- Vibe init: apply saved theme before first paint to avoid flash -->
  <script is:inline>
    (function(){
      var v = localStorage.getItem('togblocks_vibe') || 'cobalt';
      if (v !== 'cobalt') document.documentElement.setAttribute('data-vibe', v);
    })();
  </script>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header">
    <div class="wrap nav">
      <a class="brand" href="/" aria-label="TógBlocks home">
        <!--
          Stud-dot T — 11 stud circles forming the letter T,
          viewed from above like looking straight down at the product.
          5 studs across (top bar) + 6 studs down (stem). Step=10.
        -->
        <svg class="brand-icon" viewBox="-1 -1 46 66" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <radialGradient id="sg" cx="38%" cy="32%" r="60%">
              <stop offset="0"   stop-color="white" stop-opacity=".55"/>
              <stop offset="100%" stop-color="black" stop-opacity=".0"/>
            </radialGradient>
          </defs>
          <!-- top bar studs (row 0, cols 0–4) -->
          <circle cx="2"  cy="2"  r="4.5" fill="var(--green)"/>
          <circle cx="2"  cy="2"  r="4.5" fill="url(#sg)"/>
          <circle cx="12" cy="2"  r="4.5" fill="var(--green)"/>
          <circle cx="12" cy="2"  r="4.5" fill="url(#sg)"/>
          <circle cx="22" cy="2"  r="4.5" fill="var(--orange)"/>
          <circle cx="22" cy="2"  r="4.5" fill="url(#sg)"/>
          <circle cx="32" cy="2"  r="4.5" fill="var(--green)"/>
          <circle cx="32" cy="2"  r="4.5" fill="url(#sg)"/>
          <circle cx="42" cy="2"  r="4.5" fill="var(--green)"/>
          <circle cx="42" cy="2"  r="4.5" fill="url(#sg)"/>
          <!-- stem studs (col 2, rows 1–6) -->
          <circle cx="22" cy="12" r="4.5" fill="var(--orange)"/>
          <circle cx="22" cy="12" r="4.5" fill="url(#sg)"/>
          <circle cx="22" cy="22" r="4.5" fill="var(--orange)"/>
          <circle cx="22" cy="22" r="4.5" fill="url(#sg)"/>
          <circle cx="22" cy="32" r="4.5" fill="var(--orange)"/>
          <circle cx="22" cy="32" r="4.5" fill="url(#sg)"/>
          <circle cx="22" cy="42" r="4.5" fill="var(--orange)"/>
          <circle cx="22" cy="42" r="4.5" fill="url(#sg)"/>
          <circle cx="22" cy="52" r="4.5" fill="var(--orange)"/>
          <circle cx="22" cy="52" r="4.5" fill="url(#sg)"/>
          <circle cx="22" cy="62" r="4.5" fill="var(--orange)"/>
          <circle cx="22" cy="62" r="4.5" fill="url(#sg)"/>
        </svg>
        <span class="brand-word">Tóg<em>Blocks</em></span>
      </a>

      <nav aria-label="Primary">
        <ul class="nav-links desktop">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={currentPage === item.href ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="nav-actions">
        <a class="cart-btn" href="/cart" aria-label="Basket">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 7h12l-1 13H7L6 7z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            <path d="M9 7a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="cart-count" data-cart-count>0</span>
        </a>
        <button
          class="menu-toggle"
          data-menu-toggle
          aria-expanded="false"
          aria-controls="mmenu"
          aria-label="Open menu"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <div class="mobile-menu" id="mmenu" data-mobile-menu>
    <ul>
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            aria-current={currentPage === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li><a href="/cart" aria-current={currentPage === '/cart' ? 'page' : undefined}>Basket</a></li>
    </ul>
  </div>

  <main id="main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <div class="footer-grid">
        <div>
          <a class="brand brand--footer" href="/" aria-label="TógBlocks home" style="margin-bottom:14px">
            <svg class="brand-icon" viewBox="-1 -1 46 66" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <radialGradient id="sgf" cx="38%" cy="32%" r="60%">
                  <stop offset="0"    stop-color="white" stop-opacity=".5"/>
                  <stop offset="100%" stop-color="black" stop-opacity=".0"/>
                </radialGradient>
              </defs>
              <circle cx="2"  cy="2"  r="4.5" fill="white" opacity=".7"/>
              <circle cx="2"  cy="2"  r="4.5" fill="url(#sgf)"/>
              <circle cx="12" cy="2"  r="4.5" fill="white" opacity=".7"/>
              <circle cx="12" cy="2"  r="4.5" fill="url(#sgf)"/>
              <circle cx="22" cy="2"  r="4.5" fill="var(--orange)"/>
              <circle cx="22" cy="2"  r="4.5" fill="url(#sgf)"/>
              <circle cx="32" cy="2"  r="4.5" fill="white" opacity=".7"/>
              <circle cx="32" cy="2"  r="4.5" fill="url(#sgf)"/>
              <circle cx="42" cy="2"  r="4.5" fill="white" opacity=".7"/>
              <circle cx="42" cy="2"  r="4.5" fill="url(#sgf)"/>
              <circle cx="22" cy="12" r="4.5" fill="var(--orange)"/>
              <circle cx="22" cy="12" r="4.5" fill="url(#sgf)"/>
              <circle cx="22" cy="22" r="4.5" fill="var(--orange)"/>
              <circle cx="22" cy="22" r="4.5" fill="url(#sgf)"/>
              <circle cx="22" cy="32" r="4.5" fill="var(--orange)"/>
              <circle cx="22" cy="32" r="4.5" fill="url(#sgf)"/>
              <circle cx="22" cy="42" r="4.5" fill="var(--orange)"/>
              <circle cx="22" cy="42" r="4.5" fill="url(#sgf)"/>
              <circle cx="22" cy="52" r="4.5" fill="var(--orange)"/>
              <circle cx="22" cy="52" r="4.5" fill="url(#sgf)"/>
              <circle cx="22" cy="62" r="4.5" fill="var(--orange)"/>
              <circle cx="22" cy="62" r="4.5" fill="url(#sgf)"/>
            </svg>
            <span class="brand-word" style="color:#fff">Tóg<em style="color:var(--orange)">Blocks</em></span>
          </a>
          <p style="color:rgba(255,255,255,.75);max-width:30ch">
            Custom names in bricks, hand-built in Ireland. <em>Tóg</em> is Irish for "build".
          </p>
        </div>
        <div>
          <h4>Shop</h4>
          <ul>
            <li><a href="/products">All products</a></li>
            <li><a href="/products/brick-letters">Brick Name Letters</a></li>
            <li><a href="/products/door-sign">Door / Room Sign</a></li>
            <li><a href="/cart">Basket</a></li>
          </ul>
        </div>
        <div>
          <h4>Company</h4>
          <ul>
            <li><a href="/about">Our story</a></li>
            <li><a href="/faq">FAQ</a></li>
            <li><a href="/faq#shipping">Shipping</a></li>
          </ul>
        </div>
        <div>
          <h4>Stay in touch</h4>
          <p style="color:rgba(255,255,255,.75);margin-bottom:12px">The odd email, the odd discount.</p>
          <form class="newsletter-form" data-newsletter>
            <label class="sr-only" for="nlf">Email</label>
            <input class="input" id="nlf" type="email" required placeholder="you@example.ie" />
            <button class="btn btn--cta btn--sm" type="submit">Join</button>
          </form>
          <p data-newsletter-msg hidden></p>
        </div>
      </div>
      <div class="footer-disclaimer">
        <span>
          Compatible with LEGO®. TógBlocks is independent and not affiliated with, endorsed by,
          or sponsored by the LEGO Group. LEGO® is a trademark of the LEGO Group.
        </span>
        <span>© <span data-year></span> TógBlocks · Made in Ireland 🇮🇪</span>
      </div>
    </div>
  </footer>

  <script>
    import '../scripts/site.ts';
  </script>
  <script>
    import '../scripts/vibes.ts';
  </script>
  <script>
    import '../scripts/slider.ts';
  </script>
</body>
</html>
