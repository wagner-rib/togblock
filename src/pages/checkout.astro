---
import Base from '../layouts/Base.astro';
import { getTokenFromRequest, getSession } from '../lib/auth';
import { FONT } from '../builder/brickfont';

const token = getTokenFromRequest(Astro.request);
const user  = token ? await getSession(token) : null;
const stripePublicKey = import.meta.env.STRIPE_PUBLIC_KEY ?? '';

const countries = [
  { code: 'IE', label: 'Ireland' },
  { code: 'GB', label: 'United Kingdom' },
  { divider: true },
  { code: 'AT', label: 'Austria' },
  { code: 'BE', label: 'Belgium' },
  { code: 'BG', label: 'Bulgaria' },
  { code: 'CY', label: 'Cyprus' },
  { code: 'CZ', label: 'Czech Republic' },
  { code: 'DE', label: 'Germany' },
  { code: 'DK', label: 'Denmark' },
  { code: 'EE', label: 'Estonia' },
  { code: 'ES', label: 'Spain' },
  { code: 'FI', label: 'Finland' },
  { code: 'FR', label: 'France' },
  { code: 'GR', label: 'Greece' },
  { code: 'HR', label: 'Croatia' },
  { code: 'HU', label: 'Hungary' },
  { code: 'IT', label: 'Italy' },
  { code: 'LT', label: 'Lithuania' },
  { code: 'LU', label: 'Luxembourg' },
  { code: 'LV', label: 'Latvia' },
  { code: 'MT', label: 'Malta' },
  { code: 'NL', label: 'Netherlands' },
  { code: 'PL', label: 'Poland' },
  { code: 'PT', label: 'Portugal' },
  { code: 'RO', label: 'Romania' },
  { code: 'SE', label: 'Sweden' },
  { code: 'SI', label: 'Slovenia' },
  { code: 'SK', label: 'Slovakia' },
  { divider: true },
  { code: 'US', label: 'United States' },
];
---

<Base
  title="Checkout — TógBlocks"
  description="Complete your TógBlocks order."
  currentPage="/checkout"
>

  <div class="co-wrap">

    <!-- ═══ LEFT: FORM ═══ -->
    <div class="co-form-col">

      <!-- Auth banner -->
      {!user && (
        <div class="co-auth-banner">
          <div class="co-auth-banner__text">
            <strong>Save your details for next time</strong>
            <span>Sign in with Google — totally optional</span>
          </div>
          <a href="/login?returnTo=/checkout" class="btn btn--google">
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Sign in with Google
          </a>
        </div>
      )}
      {user && (
        <div class="co-user-banner">
          {user.pictureUrl && <img src={user.pictureUrl} alt="" class="co-user-avatar" />}
          <div>
            <strong>{user.name}</strong>
            <span>{user.email}</span>
          </div>
          <form method="POST" action="/api/auth/logout" style="margin-left:auto">
            <button type="submit" class="co-signout-btn">Sign out</button>
          </form>
        </div>
      )}

      <h1 class="co-heading">Checkout</h1>

      <!-- Contact -->
      <section class="co-section">
        <h2 class="co-section__title">Contact</h2>
        <div class="field-row">
          <label class="field-label" for="co-email">Email address <span class="req">*</span></label>
          <input class="input" id="co-email" name="email" type="email" required
                 autocomplete="email" value={user?.email ?? ''} placeholder="you@example.ie" />
          <p class="field-hint">Order confirmation sent here</p>
        </div>
      </section>

      <!-- Delivery address -->
      <section class="co-section">
        <h2 class="co-section__title">Delivery address</h2>

        <div class="field-row">
          <label class="field-label" for="co-name">Full name <span class="req">*</span></label>
          <input class="input" id="co-name" name="name" type="text" required
                 autocomplete="name" value={user?.name ?? ''} placeholder="Aoife Murphy" />
        </div>

        <div class="field-row">
          <label class="field-label" for="co-country">Country <span class="req">*</span></label>
          <select class="input" id="co-country" name="country" required autocomplete="country">
            {countries.map(c =>
              'divider' in c
                ? <option disabled>──────────</option>
                : <option value={c.code}>{c.label}</option>
            )}
          </select>
        </div>

        <div class="field-row">
          <label class="field-label" for="co-line1">Address line 1 <span class="req">*</span></label>
          <input class="input" id="co-line1" name="line1" type="text" required
                 autocomplete="address-line1" placeholder="14 Sycamore Drive" />
        </div>

        <div class="field-row">
          <label class="field-label" for="co-line2">Address line 2 <span class="optional">(optional)</span></label>
          <input class="input" id="co-line2" name="line2" type="text"
                 autocomplete="address-line2" placeholder="Apt, suite, etc." />
        </div>

        <div class="field-grid-2">
          <div class="field-row">
            <label class="field-label" for="co-city">Town / City <span class="req">*</span></label>
            <input class="input" id="co-city" name="city" type="text" required
                   autocomplete="address-level2" placeholder="Naas" />
          </div>
          <div class="field-row" id="co-county-field">
            <label class="field-label" for="co-county">County <span class="optional">(optional)</span></label>
            <input class="input" id="co-county" name="county" type="text"
                   autocomplete="address-level1" placeholder="Kildare" />
          </div>
        </div>

        <div class="field-row" id="co-postcode-field">
          <label class="field-label" for="co-postcode">Postcode / Eircode</label>
          <input class="input" id="co-postcode" name="postcode" type="text"
                 autocomplete="postal-code" placeholder="W91 XY12" style="max-width:200px" />
        </div>

        <!-- Shipping rate badge -->
        <div class="co-shipping-badge" id="co-shipping-badge" hidden>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3m-4 12a2 2 0 1 0 4 0 2 2 0 0 0-4 0m6-2h2l2-4-3.68-1.23A2 2 0 0 0 20.9 12H16v5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span id="co-shipping-text"></span>
        </div>
      </section>

      <!-- Notes -->
      <section class="co-section">
        <h2 class="co-section__title">Special instructions <span class="optional">(optional)</span></h2>
        <textarea class="input" id="co-notes" name="notes" rows="2"
                  placeholder="Rush order for Saturday? Leave us a note."></textarea>
      </section>

      <!-- Payment -->
      <section class="co-section">
        <h2 class="co-section__title">Payment</h2>
        <div id="co-payment-element" class="co-stripe-container">
          <div class="co-stripe-placeholder">
            <span class="co-stripe-lock">🔒</span>
            Fill in your address first
          </div>
        </div>
        <p id="co-payment-error" class="co-error" hidden></p>
      </section>

      <button class="btn btn--cta btn--lg co-submit-btn" id="co-submit" disabled>
        <span id="co-submit-label">Pay now</span>
        <span id="co-submit-spinner" class="co-spinner" hidden></span>
      </button>

      <p class="co-secure-note">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        Secured by Stripe · We never store your card details
      </p>
    </div>

    <!-- ═══ RIGHT: ORDER SUMMARY ═══ -->
    <aside class="co-summary-col">
      <div class="co-summary">
        <h2 class="co-summary__title">Order summary</h2>
        <div id="co-item-list" class="co-item-list">
          <p class="co-empty-cart">Your basket is empty.</p>
        </div>
        <div class="co-summary-divider"></div>
        <div class="co-summary-row">
          <span>Subtotal</span>
          <span id="co-subtotal">€0.00</span>
        </div>
        <div class="co-summary-row">
          <span>Shipping</span>
          <span id="co-shipping-display">—</span>
        </div>
        <div class="co-summary-divider"></div>
        <div class="co-summary-row co-summary-row--total">
          <span>Total</span>
          <span id="co-total">€0.00</span>
        </div>
      </div>
    </aside>

  </div>
</Base>

<style>
/* ── LAYOUT ───────────────────────────────────────────────── */
.co-wrap {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 40px;
  max-width: 1080px;
  margin: 0 auto;
  padding: 40px 20px 80px;
  align-items: start;
}

@media (max-width: 800px) {
  .co-wrap { grid-template-columns: 1fr; }
  .co-summary-col { order: -1; }
}

/* ── HEADING ──────────────────────────────────────────────── */
.co-heading {
  font-family: var(--font-display);
  font-size: var(--fs-2xl);
  font-weight: 800;
  color: var(--ink);
  margin: 24px 0 8px;
}

/* ── AUTH BANNERS ─────────────────────────────────────────── */
.co-auth-banner {
  display: flex;
  align-items: center;
  gap: 16px;
  background: var(--green-soft);
  border: 1.5px solid var(--green);
  border-radius: var(--radius-lg);
  padding: 14px 20px;
  flex-wrap: wrap;
}
.co-auth-banner__text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  flex: 1;
}
.co-auth-banner__text strong { font-size: var(--fs-sm); color: var(--ink); }
.co-auth-banner__text span   { font-size: var(--fs-xs); color: var(--ink-60); }

.btn--google {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  border: 1.5px solid var(--line);
  border-radius: 999px;
  padding: 8px 18px;
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--ink);
  text-decoration: none;
  white-space: nowrap;
  transition: box-shadow .15s;
}
.btn--google:hover { box-shadow: 0 2px 8px rgba(0,0,0,.1); }

.co-user-banner {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--offwhite);
  border: 1.5px solid var(--line);
  border-radius: var(--radius-lg);
  padding: 12px 16px;
}
.co-user-avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  object-fit: cover;
}
.co-user-banner strong { display: block; font-size: var(--fs-sm); color: var(--ink); }
.co-user-banner span   { font-size: var(--fs-xs); color: var(--ink-60); }
.co-signout-btn {
  background: none; border: none; cursor: pointer;
  font-size: var(--fs-xs); color: var(--ink-60); padding: 4px 8px;
  border-radius: var(--radius);
  transition: background .15s;
}
.co-signout-btn:hover { background: var(--line); }

/* ── FORM SECTIONS ────────────────────────────────────────── */
.co-section { margin-bottom: 28px; }
.co-section__title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: var(--fs-sm);
  color: var(--ink);
  margin: 0 0 14px;
  padding-bottom: 8px;
  border-bottom: 1.5px solid var(--line);
}

.field-row { margin-bottom: 14px; }
.field-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 480px) { .field-grid-2 { grid-template-columns: 1fr; } }

.field-label {
  display: block;
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 5px;
}
.req { color: #dc2626; }
.optional { color: var(--ink-40); font-weight: 400; font-size: .85em; }

/* ── SHIPPING BADGE ───────────────────────────────────────── */
.co-shipping-badge {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--green-soft);
  border: 1px solid var(--green);
  border-radius: var(--radius);
  padding: 8px 12px;
  font-size: var(--fs-xs);
  font-weight: 600;
  color: var(--green-deep);
  margin-top: 10px;
}

/* ── STRIPE CONTAINER ─────────────────────────────────────── */
.co-stripe-container {
  background: var(--offwhite);
  border: 1.5px solid var(--line);
  border-radius: var(--radius-lg);
  padding: 20px;
  min-height: 80px;
}
.co-stripe-placeholder {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--ink-40);
  font-size: var(--fs-sm);
}
.co-stripe-lock { font-size: 20px; }

/* ── SUBMIT ───────────────────────────────────────────────── */
.co-submit-btn {
  width: 100%;
  justify-content: center;
  margin-bottom: 12px;
  font-size: var(--fs-md);
  padding: 16px;
}
.co-submit-btn:disabled {
  opacity: .55;
  cursor: not-allowed;
}

.co-spinner {
  display: inline-block;
  width: 16px; height: 16px;
  border: 2px solid rgba(255,255,255,.4);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.co-error {
  color: #dc2626;
  font-size: var(--fs-sm);
  margin-top: 10px;
}

.co-secure-note {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: var(--fs-xs);
  color: var(--ink-40);
  justify-content: center;
}

/* ── ORDER SUMMARY ────────────────────────────────────────── */
.co-summary {
  background: var(--white);
  border: 1.5px solid var(--line);
  border-radius: var(--radius-xl);
  padding: 24px;
  position: sticky;
  top: 90px;
}
.co-summary__title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: var(--fs-sm);
  color: var(--ink);
  margin: 0 0 16px;
}
.co-item-list { margin-bottom: 16px; }
.co-empty-cart { color: var(--ink-40); font-size: var(--fs-sm); }

.co-summary-divider {
  height: 1px;
  background: var(--line);
  margin: 12px 0;
}
.co-summary-row {
  display: flex;
  justify-content: space-between;
  font-size: var(--fs-sm);
  color: var(--ink-60);
  margin-bottom: 6px;
}
.co-summary-row--total {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: var(--fs-md);
  color: var(--ink);
  margin-top: 4px;
}

/* ── CART ITEM CARD ───────────────────────────────────────── */
.co-item {
  background: var(--white);
  border: 1.5px solid var(--line);
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 10px;
}
.co-item:last-child { margin-bottom: 0; }

/* Brick preview strip */
.co-item-preview {
  background: var(--offwhite);
  border-bottom: 1px solid var(--line);
  padding: 12px 16px 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 52px;
}

/* Details row */
.co-item-body {
  padding: 10px 14px 12px;
}
.co-item-row1 {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 8px;
  margin-bottom: 1px;
}
.co-item-name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: var(--fs-sm);
  color: var(--ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}
.co-item-price {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: var(--fs-sm);
  color: var(--ink);
  flex-shrink: 0;
}
.co-item-type {
  font-size: 11px;
  color: var(--ink-40);
  margin-bottom: 10px;
}

/* Controls row */
.co-item-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.co-qty-pill {
  display: inline-flex;
  align-items: center;
  border: 1.5px solid var(--line);
  border-radius: 999px;
  overflow: hidden;
  background: var(--offwhite);
}
.co-qty-btn {
  width: 30px; height: 28px;
  border: none;
  background: transparent;
  font-size: 16px;
  line-height: 1;
  cursor: pointer;
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .15s;
  padding: 0;
}
.co-qty-btn:hover { background: var(--line); }
.co-qty-val {
  font-size: var(--fs-xs);
  font-weight: 700;
  color: var(--ink);
  min-width: 26px;
  text-align: center;
  border-left: 1.5px solid var(--line);
  border-right: 1.5px solid var(--line);
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--white);
}
.co-remove-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-40);
  font-size: 11px;
  font-weight: 600;
  padding: 2px 0;
  transition: color .15s;
}
.co-remove-btn:hover { color: #dc2626; }
</style>

<script define:vars={{ stripePublicKey, FONT }}>
// ── Cart → summary ──────────────────────────────────────────
// Cart items from the builder use: price (€ integer), qty, name, type ('custom-name'|'door-sign')
// All monetary values here are in EURO CENTS for consistency with Stripe

function eurosToCents(euros) { return Math.round(euros * 100); }
function formatCents(cents)  { return `€${(cents / 100).toFixed(2)}`; }

const shippingRates = { IE: 495, GB: 495, EU: 495, US: 699 };
const euCountries   = new Set(['AT','BE','BG','CY','CZ','DE','DK','EE','ES','FI','FR','GR',
  'HR','HU','IT','LT','LU','LV','MT','NL','PL','PT','RO','SE','SI','SK']);

function classifyCountry(iso) {
  if (iso === 'IE') return 'IE';
  if (iso === 'GB') return 'GB';
  if (euCountries.has(iso)) return 'EU';
  if (iso === 'US') return 'US';
  return 'OTHER';
}

function calcShipping(country, subtotalCents) {
  const region = classifyCountry(country);
  if (region === 'IE' && subtotalCents >= 4000) return 0;
  return shippingRates[region] ?? 0;
}

const shippingLabel = {
  IE: 'Ireland · 1–3 days',
  GB: 'UK · 3–5 days',
  EU: 'EU · 4–7 days',
  US: 'USA · 5–10 days',
};

// Normalize a raw cart item → checkout shape (unit_price in cents)
function normalize(item) {
  return {
    product_type: item.type === 'door-sign' ? 'door-sign' : 'letters',
    custom_name:  item.name  ?? '',
    colours:      (item.letters ?? []).map(l => l.colour),
    quantity:     item.qty   ?? 1,
    unit_price:   eurosToCents(item.price ?? 0),
  };
}

let cart = [];
let stripe = null;
let elements = null;
let paymentElement = null;
let currentOrderId = null;

function loadCart() {
  try { cart = JSON.parse(localStorage.getItem('togblocks_cart') || '[]'); } catch { cart = []; }
}

function renderSummary(country) {
  const list       = document.getElementById('co-item-list');
  const subtotalEl = document.getElementById('co-subtotal');
  const shippingEl = document.getElementById('co-shipping-display');
  const totalEl    = document.getElementById('co-total');

  if (!cart.length) {
    list.innerHTML = '<p class="co-empty-cart">Your basket is empty.</p>';
    subtotalEl.textContent = '€0.00';
    shippingEl.textContent = '—';
    totalEl.textContent    = '€0.00';
    return;
  }

  // subtotal in cents
  const subtotal = cart.reduce((s, i) => s + eurosToCents(i.price ?? 0) * (i.qty || 1), 0);
  const shipping = country ? calcShipping(country, subtotal) : null;
  const total    = subtotal + (shipping ?? 0);

  const isDoorSign = i => i.type === 'door-sign';

  function brickPreviewSVG(item) {
    const name    = (item.name || '').toUpperCase();
    const letters = item.letters || [];
    const cell    = 4;    // px per grid square
    const gap     = 3;    // px gap between letters
    const rows    = 7;
    const cols    = 5;
    const lw      = cols * cell;

    // Calculate total width
    let totalW = 0;
    for (const ch of name) {
      totalW += (ch === ' ' ? Math.round(lw * 0.6) : lw) + gap;
    }
    totalW = Math.max(totalW - gap, 1);
    const totalH = rows * cell;

    let rects = '';
    let x = 0;
    let colIdx = 0;

    for (const ch of name) {
      if (ch === ' ') { x += Math.round(lw * 0.6) + gap; continue; }
      const grid   = FONT[ch];
      const colour = letters[colIdx]?.colour || '#1D4ED8';
      colIdx++;
      if (!grid) { x += lw + gap; continue; }

      grid.forEach((rowStr, rowIdx) => {
        for (let c = 0; c < rowStr.length; c++) {
          if (rowStr[c] === '1') {
            rects += `<rect x="${x + c * cell}" y="${rowIdx * cell}" width="${cell - 1}" height="${cell - 1}" rx="1" fill="${colour}"/>`;
          }
        }
      });
      x += lw + gap;
    }

    // Door sign fallback: coloured baseplate with studs
    if (isDoorSign(item)) {
      const bg  = item.plateColour  || '#1D4ED8';
      const txt = item.textColour   || '#FACC15';
      const sw  = 80; const sh = 28;
      let studs = '';
      for (let sc = 0; sc < 8; sc++) {
        studs += `<circle cx="${5 + sc * 10}" cy="14" r="3.5" fill="rgba(255,255,255,.25)"/>`;
      }
      const label = name.slice(0, 8);
      return `<svg viewBox="0 0 ${sw} ${sh}" xmlns="http://www.w3.org/2000/svg" style="display:block;width:100%;max-height:40px">
        <rect width="${sw}" height="${sh}" rx="5" fill="${bg}"/>
        ${studs}
        <text x="${sw/2}" y="${sh/2 + 4}" text-anchor="middle" font-size="10" font-weight="700" fill="${txt}" font-family="monospace">${label}</text>
      </svg>`;
    }

    return `<svg viewBox="0 0 ${totalW} ${totalH}" xmlns="http://www.w3.org/2000/svg" style="display:block;width:100%;max-height:36px">${rects}</svg>`;
  }

  list.innerHTML = cart.map((item, idx) => `
    <div class="co-item" data-idx="${idx}">
      <div class="co-item-preview" aria-hidden="true">${brickPreviewSVG(item)}</div>
      <div class="co-item-body">
        <div class="co-item-row1">
          <span class="co-item-name">${item.name || '(name)'}</span>
          <span class="co-item-price">${formatCents(eurosToCents(item.price ?? 0) * (item.qty || 1))}</span>
        </div>
        <div class="co-item-type">${isDoorSign(item) ? 'Door Sign' : 'Brick Letters'} &nbsp;·&nbsp; €${item.price ?? 0} each</div>
        <div class="co-item-controls">
          <div class="co-qty-pill">
            <button class="co-qty-btn" data-action="dec" data-idx="${idx}" aria-label="Decrease quantity">−</button>
            <span class="co-qty-val">${item.qty || 1}</span>
            <button class="co-qty-btn" data-action="inc" data-idx="${idx}" aria-label="Increase quantity">+</button>
          </div>
          <button class="co-remove-btn" data-action="remove" data-idx="${idx}" aria-label="Remove item">Remove <svg width="11" height="11" viewBox="0 0 24 24" fill="none" style="display:inline;vertical-align:middle" aria-hidden="true"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        </div>
      </div>
    </div>
  `).join('');

  // Wire up edit controls
  list.querySelectorAll('[data-action]').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx    = Number(btn.dataset.idx);
      const action = btn.dataset.action;
      if (action === 'remove') {
        cart.splice(idx, 1);
      } else if (action === 'inc') {
        cart[idx].qty = (cart[idx].qty || 1) + 1;
      } else if (action === 'dec') {
        if ((cart[idx].qty || 1) > 1) {
          cart[idx].qty = (cart[idx].qty || 1) - 1;
        } else {
          cart.splice(idx, 1);
        }
      }
      localStorage.setItem('togblocks_cart', JSON.stringify(cart));
      document.dispatchEvent(new CustomEvent('cart:update'));
      const country = document.getElementById('co-country').value;
      renderSummary(country);
      // Reset Stripe so a new PaymentIntent is created with the updated total
      resetStripe(country);
    });
  });

  subtotalEl.textContent = formatCents(subtotal);
  shippingEl.textContent = shipping === null ? '—' : (shipping === 0 ? 'Free 🎉' : formatCents(shipping));
  totalEl.textContent    = shipping === null ? '—' : formatCents(total);

  const badge    = document.getElementById('co-shipping-badge');
  const badgeTxt = document.getElementById('co-shipping-text');
  if (country && shipping !== null) {
    const region = classifyCountry(country);
    badgeTxt.textContent = shipping === 0
      ? 'Free shipping — over €40 to Ireland!'
      : `Shipping: ${formatCents(shipping)} · ${shippingLabel[region] || ''}`;
    badge.hidden = false;
  } else {
    badge.hidden = true;
  }
}

function resetStripe(country) {
  elements = null;
  paymentElement = null;
  currentOrderId = null;
  document.getElementById('co-submit').disabled = true;
  if (!cart.length) {
    document.getElementById('co-payment-element').innerHTML =
      '<div class="co-stripe-placeholder"><span class="co-stripe-lock">🔒</span>Your basket is empty</div>';
    return;
  }
  document.getElementById('co-payment-element').innerHTML =
    '<div class="co-stripe-placeholder"><span class="co-stripe-lock">🔒</span>Updating…</div>';
  scheduleInit(country);
}

// ── Stripe initialisation ───────────────────────────────────
async function initStripe(country) {
  if (!stripePublicKey) return;
  if (!cart.length) return;

  const email   = document.getElementById('co-email').value.trim();
  const name    = document.getElementById('co-name').value.trim();
  const line1   = document.getElementById('co-line1').value.trim();
  const city    = document.getElementById('co-city').value.trim();

  if (!email || !name || !line1 || !city || !country) return;

  const region = classifyCountry(country);
  if (region === 'OTHER') return; // handled by email

  const container = document.getElementById('co-payment-element');

  try {
    const res = await fetch('/api/checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        items:   cart.map(normalize),
        email,
        address: {
          name, country,
          line1,
          line2:    document.getElementById('co-line2').value.trim() || undefined,
          city,
          county:   document.getElementById('co-county').value.trim() || undefined,
          postcode: document.getElementById('co-postcode').value.trim() || undefined,
        },
        notes: document.getElementById('co-notes').value.trim() || undefined,
      }),
    });

    const data = await res.json();
    if (!res.ok || !data.clientSecret) throw new Error(data.error || 'Checkout failed');

    currentOrderId = data.orderId;

    if (!stripe) stripe = Stripe(stripePublicKey);

    if (elements) {
      elements.update({ amount: data.total });
    } else {
      elements = stripe.elements({
        clientSecret: data.clientSecret,
        appearance:   { theme: 'stripe', variables: { colorPrimary: '#1D4ED8', borderRadius: '10px' } },
      });
      paymentElement = elements.create('payment', { layout: 'tabs' });
      container.innerHTML = '';
      paymentElement.mount('#co-payment-element');
    }

    document.getElementById('co-submit').disabled = false;
  } catch (err) {
    container.innerHTML = `<p class="co-error">${err.message}</p>`;
  }
}

// ── Form & events ────────────────────────────────────────────
let initTimer;
function scheduleInit(country) {
  clearTimeout(initTimer);
  const c = country ?? document.getElementById('co-country')?.value;
  initTimer = setTimeout(() => initStripe(c), 600);
}

document.addEventListener('DOMContentLoaded', () => {
  loadCart();
  renderSummary(null);

  const countryEl  = document.getElementById('co-country');
  const submitBtn  = document.getElementById('co-submit');
  const errorEl    = document.getElementById('co-payment-error');

  // Default to Ireland
  countryEl.value = 'IE';
  renderSummary('IE');

  countryEl.addEventListener('change', () => {
    renderSummary(countryEl.value);
    if (elements) {
      elements = null; paymentElement = null;
      document.getElementById('co-payment-element').innerHTML =
        '<div class="co-stripe-placeholder"><span class="co-stripe-lock">🔒</span>Updating payment…</div>';
      submitBtn.disabled = true;
    }
    scheduleInit(countryEl.value);
  });

  ['co-email','co-name','co-line1','co-city'].forEach(id => {
    document.getElementById(id)?.addEventListener('blur', () => scheduleInit(null));
  });

  submitBtn.addEventListener('click', async () => {
    if (!elements || !stripe) return;
    errorEl.hidden = true;
    submitBtn.disabled = true;
    document.getElementById('co-submit-label').textContent = 'Processing…';
    document.getElementById('co-submit-spinner').hidden = false;

    const origin = window.location.origin;
    const { error } = await stripe.confirmPayment({
      elements,
      confirmParams: {
        return_url: `${origin}/orders/${currentOrderId}?success=1`,
        payment_method_data: {
          billing_details: {
            email: document.getElementById('co-email').value.trim(),
            name:  document.getElementById('co-name').value.trim(),
          },
        },
      },
    });

    if (error) {
      errorEl.textContent = error.message;
      errorEl.hidden = false;
      submitBtn.disabled = false;
      document.getElementById('co-submit-label').textContent = 'Pay now';
      document.getElementById('co-submit-spinner').hidden = true;
    }
  });
});
</script>
