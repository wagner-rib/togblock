---
import Base from '../../layouts/Base.astro';
import { getTokenFromRequest, getSession } from '../../lib/auth';
import { query } from '../../lib/db';

const { id } = Astro.params;
const orderId = Number(id);

if (!orderId || isNaN(orderId)) return Astro.redirect('/');

const token = getTokenFromRequest(Astro.request);
const user  = token ? await getSession(token) : null;
const success = Astro.url.searchParams.get('success') === '1';

// Fetch order
const orderRes = await query<{
  id: number; status: string; subtotal: number; shipping_cost: number; total: number;
  guest_email: string | null; created_at: Date;
}>(
  'SELECT id, status, subtotal, shipping_cost, total, guest_email, created_at FROM orders WHERE id = $1',
  [orderId]
);

if (!orderRes.rows.length) return Astro.redirect('/');
const order = orderRes.rows[0];

// Items
const itemsRes = await query<{
  product_type: string; custom_name: string; quantity: number; unit_price: number;
}>(
  'SELECT product_type, custom_name, quantity, unit_price FROM order_items WHERE order_id = $1',
  [orderId]
);

// Address
const addrRes = await query<{
  name: string; line1: string; line2: string | null; city: string;
  county: string | null; postcode: string | null; country: string;
}>(
  'SELECT a.name, a.line1, a.line2, a.city, a.county, a.postcode, a.country FROM orders o JOIN addresses a ON a.id = o.address_id WHERE o.id = $1',
  [orderId]
);

const addr = addrRes.rows[0];
const items = itemsRes.rows;

function formatPrice(cents: number) {
  return `€${(cents / 100).toFixed(2)}`;
}

const orderRef = `#TB${String(order.id).padStart(5, '0')}`;
// Trust ?success=1 from Stripe's redirect — webhook updates DB asynchronously
const isPaid   = order.status === 'paid' || success;
---

<Base
  title={`Order ${orderRef} — TógBlocks`}
  description="Your TógBlocks order confirmation."
  currentPage="/orders"
>
  <div class="ord-wrap">

    {success && (
      <div class="ord-success-banner">
        <span class="ord-success-icon">🎉</span>
        <div>
          <strong>Payment confirmed — we're building it now!</strong>
          <span>A confirmation email is on its way to you.</span>
        </div>
      </div>
    )}

    <div class="ord-header">
      <h1 class="ord-title">Order {orderRef}</h1>
      <span class={`ord-badge ${isPaid ? 'ord-badge--paid' : 'ord-badge--pending'}`}>
        {isPaid ? '✓ Paid' : order.status.replace(/_/g, ' ')}
      </span>
    </div>

    <div class="ord-grid">

      <!-- Items -->
      <section class="ord-section">
        <h2 class="ord-section__title">Items ordered</h2>
        {items.map(item => (
          <div class="ord-item">
            <div class="ord-item__icon">{item.product_type === 'door-sign' ? '🚪' : '🧱'}</div>
            <div class="ord-item__info">
              <strong>{item.custom_name}</strong>
              <span>{item.product_type === 'door-sign' ? 'Door Sign' : 'Brick Letters'} · qty {item.quantity}</span>
            </div>
            <div class="ord-item__price">{formatPrice(item.unit_price * item.quantity)}</div>
          </div>
        ))}
        <div class="ord-totals">
          <div class="ord-total-row">
            <span>Subtotal</span>
            <span>{formatPrice(order.subtotal)}</span>
          </div>
          <div class="ord-total-row">
            <span>Shipping</span>
            <span>{order.shipping_cost === 0 ? 'Free' : formatPrice(order.shipping_cost)}</span>
          </div>
          <div class="ord-total-row ord-total-row--grand">
            <span>Total</span>
            <span>{formatPrice(order.total)}</span>
          </div>
        </div>
      </section>

      <!-- Delivery address -->
      {addr && (
        <section class="ord-section">
          <h2 class="ord-section__title">Delivery address</h2>
          <address class="ord-address">
            {addr.name}<br />
            {addr.line1}<br />
            {addr.line2 && <>{addr.line2}<br /></>}
            {addr.city}<br />
            {addr.county && <>{addr.county}<br /></>}
            {addr.postcode && <>{addr.postcode}<br /></>}
            {addr.country}
          </address>
        </section>
      )}

    </div>

    <!-- What happens next -->
    <div class="ord-next-steps">
      <h2 class="ord-section__title">What happens next?</h2>
      <div class="ord-steps">
        <div class="ord-step">
          <span class="ord-step__num">1</span>
          <div>
            <strong>Printing</strong>
            <p>Your build is 3D printed and quality-checked within 2–3 working days.</p>
          </div>
        </div>
        <div class="ord-step">
          <span class="ord-step__num">2</span>
          <div>
            <strong>Posted</strong>
            <p>Handed to An Post in protective packaging. You'll get tracking if available.</p>
          </div>
        </div>
        <div class="ord-step">
          <span class="ord-step__num">3</span>
          <div>
            <strong>Arrived!</strong>
            <p>Enjoy — and if you share a photo we'd love to see it. 💚</p>
          </div>
        </div>
      </div>
    </div>

    <div class="ord-actions">
      <a class="btn btn--cta" href="/builder">Build another →</a>
      <a class="btn" href="/products">Browse products</a>
    </div>

  </div>
</Base>

<style>
.ord-wrap {
  max-width: 720px;
  margin: 0 auto;
  padding: 40px 20px 80px;
}

.ord-success-banner {
  display: flex;
  align-items: center;
  gap: 16px;
  background: #dcfce7;
  border: 1.5px solid #16a34a;
  border-radius: var(--radius-lg);
  padding: 16px 20px;
  margin-bottom: 28px;
}
.ord-success-icon { font-size: 28px; }
.ord-success-banner strong { display: block; color: #15803d; font-weight: 700; }
.ord-success-banner span   { font-size: var(--fs-sm); color: #166534; }

.ord-header {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 32px;
  flex-wrap: wrap;
}
.ord-title {
  font-family: var(--font-display);
  font-size: var(--fs-2xl);
  font-weight: 800;
  color: var(--ink);
  margin: 0;
}

.ord-badge {
  padding: 4px 14px;
  border-radius: 999px;
  font-size: var(--fs-xs);
  font-weight: 700;
}
.ord-badge--paid    { background: #dcfce7; color: #15803d; }
.ord-badge--pending { background: #fef9c3; color: #854d0e; }

.ord-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-bottom: 32px;
}
@media (max-width: 600px) { .ord-grid { grid-template-columns: 1fr; } }

.ord-section {
  background: var(--white);
  border: 1.5px solid var(--line);
  border-radius: var(--radius-xl);
  padding: 20px;
}
.ord-section__title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: var(--fs-sm);
  color: var(--ink);
  margin: 0 0 16px;
}

.ord-item {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}
.ord-item__icon {
  width: 44px; height: 44px;
  background: var(--offwhite);
  border-radius: var(--radius);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; flex-shrink: 0;
}
.ord-item__info { flex: 1; }
.ord-item__info strong { display: block; font-size: var(--fs-sm); color: var(--ink); }
.ord-item__info span   { font-size: var(--fs-xs); color: var(--ink-40); }
.ord-item__price { font-weight: 700; font-size: var(--fs-sm); white-space: nowrap; }

.ord-totals { border-top: 1px solid var(--line); padding-top: 12px; margin-top: 12px; }
.ord-total-row {
  display: flex; justify-content: space-between;
  font-size: var(--fs-sm); color: var(--ink-60);
  margin-bottom: 6px;
}
.ord-total-row--grand {
  font-family: var(--font-display);
  font-weight: 800; font-size: var(--fs-md);
  color: var(--ink); margin-top: 8px;
}

.ord-address {
  font-style: normal;
  line-height: 1.8;
  font-size: var(--fs-sm);
  color: var(--ink-60);
}

.ord-next-steps {
  background: var(--green-soft);
  border-radius: var(--radius-xl);
  padding: 24px;
  margin-bottom: 32px;
}
.ord-steps { display: flex; flex-direction: column; gap: 16px; }
.ord-step {
  display: flex;
  gap: 14px;
  align-items: flex-start;
}
.ord-step__num {
  width: 28px; height: 28px;
  background: var(--green);
  color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 800; font-size: var(--fs-xs);
  flex-shrink: 0; margin-top: 2px;
}
.ord-step strong { display: block; font-size: var(--fs-sm); color: var(--ink); margin-bottom: 2px; }
.ord-step p { margin: 0; font-size: var(--fs-sm); color: var(--ink-60); }

.ord-actions {
  display: flex; gap: 12px; flex-wrap: wrap;
}
</style>

<script define:vars={{ success }}>
if (success) {
  // Clear localStorage cart
  localStorage.removeItem('togblocks_cart');
  // Clear server-side cart for logged-in users
  fetch('/api/cart', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify([]),
  }).catch(() => {});
  // Update the nav cart count to 0
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-cart-count]').forEach(el => {
      el.textContent = '0';
      el.hidden = true;
    });
  });
}
</script>
