---
import Base from '../layouts/Base.astro';
---

<Base
  title="Builder — TógBlocks"
  description="Personalise your TógBlocks order. Type a name, pick colours, and get an instant 3D preview before adding to basket."
  currentPage="/builder"
>
  <section class="builder-page">
    <div class="wrap builder-page__wrap">

      <div class="builder-page__header">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Home</a></li>
            <li><a href="/products">Products</a></li>
            <li aria-current="page" data-builder-bc>Brick Name Letters</li>
          </ol>
        </nav>
        <h1 class="builder-page__title" data-builder-title>Personalise your Brick Name Letters</h1>
        <p class="builder-page__sub lead" data-builder-sub>
          Type a name, choose your colours, and get a live 3D preview. We'll build it and post it within 3 days.
        </p>
        <div class="builder-page__tabs" role="tablist" aria-label="Product type">
          <a
            href="/builder?product=letters"
            class="builder-tab"
            data-tab="letters"
            role="tab"
            aria-selected="true"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="3" y="6" width="7" height="12" rx="2" stroke="currentColor" stroke-width="2"/>
              <rect x="14" y="6" width="7" height="12" rx="2" stroke="currentColor" stroke-width="2"/>
            </svg>
            Brick Letters
          </a>
          <a
            href="/builder?product=sign"
            class="builder-tab"
            data-tab="sign"
            role="tab"
            aria-selected="false"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="2" y="7" width="20" height="10" rx="2" stroke="currentColor" stroke-width="2"/>
              <path d="M7 11h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Door Sign
          </a>
        </div>
      </div>

      <!-- Letters builder (default) -->
      <div id="builder-letters" data-builder-panel="letters">
        <div data-name-builder data-initial="ADA"></div>
      </div>

      <!-- Sign builder -->
      <div id="builder-sign" data-builder-panel="sign" hidden>
        <div data-sign-builder-host data-initial="CHARLIE"></div>
      </div>

    </div>
  </section>
</Base>

<style>
.builder-page {
  padding-block: clamp(28px, 4vw, 52px);
  background: var(--offwhite);
  min-height: calc(100vh - var(--header-h));
}
.builder-page__wrap {
  display: flex; flex-direction: column; gap: clamp(20px, 3vw, 32px);
  max-width: 940px;
}
.builder-page__header {
  display: flex; flex-direction: column; gap: 10px;
}
.builder-page__title {
  font-size: clamp(1.6rem, 1.4rem + 1vw, 2.4rem);
  color: var(--ink);
}
.builder-page__sub {
  max-width: 560px;
}
.builder-page__tabs {
  display: flex; gap: 10px; flex-wrap: wrap;
  margin-top: 4px;
}
.builder-tab {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-display); font-weight: 600; font-size: var(--fs-sm);
  padding: 10px 18px; border-radius: var(--radius-pill);
  border: 2px solid var(--line-strong);
  background: var(--white); color: var(--green-deep);
  text-decoration: none;
  transition: background .14s, border-color .14s, transform .14s var(--ease-pop);
}
.builder-tab:hover { border-color: var(--sage); transform: translateY(-1px); }
.builder-tab[aria-selected="true"] {
  background: var(--green-deep); color: var(--white); border-color: var(--green-deep);
}
</style>

<script>
  import '../builder/builder.ts';
  import { DoorSignBuilder } from '../builder/sign-builder.ts';

  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const product = params.get('product') || 'letters';

    // Show/hide panels
    const lettersPanel = document.getElementById('builder-letters');
    const signPanel = document.getElementById('builder-sign');
    const tabs = document.querySelectorAll<HTMLAnchorElement>('.builder-tab');

    if (product === 'sign') {
      if (lettersPanel) lettersPanel.hidden = true;
      if (signPanel) signPanel.hidden = false;
      // Init sign builder
      const host = signPanel?.querySelector<HTMLElement>('[data-sign-builder-host]');
      if (host && !host.dataset.sbInit) {
        host.dataset.sbInit = '1';
        new DoorSignBuilder(host);
      }
    }

    // Tab aria-selected
    tabs.forEach(tab => {
      const tabProduct = tab.dataset.tab;
      tab.setAttribute('aria-selected', String(tabProduct === product));
    });

    // Update header text
    const bc = document.querySelector('[data-builder-bc]');
    const title = document.querySelector('[data-builder-title]');
    const sub = document.querySelector('[data-builder-sub]');

    if (product === 'sign') {
      if (bc) bc.textContent = 'Door / Room Sign';
      if (title) title.textContent = 'Personalise your Door / Room Sign';
      if (sub) sub.textContent = 'Choose a plate colour, text colour, and type your name. A live preview updates instantly.';
    }
  });
</script>
