---
import Base from '../layouts/Base.astro';

const reviews = [
  { stars: 5, quote: "Ordered FINN for the cot. Arrived in three days, colours exactly as the builder showed. Genuinely chuffed — it's the first thing you see walking into his room.", name: 'Aoife O\'Brien', loc: 'Galway', init: 'AO', bg: '#169B62' },
  { stars: 5, quote: "Clicked straight onto our existing baseplate. The kids now spell out rude words with it, which is on them, not TógBlocks.", name: 'Dara Murphy', loc: 'Cork', init: 'DM', bg: '#E0473A' },
  { stars: 5, quote: "Recoloured each letter to match her room. The little preview made it impossible to get wrong. Will be back at Christmas.", name: 'Niamh Kelly', loc: 'Dublin', init: 'NK', bg: '#2563EB' },
  { stars: 5, quote: "Brilliant quality. The door sign for Charlie's room is the talk of every playdate. Fast delivery too!", name: 'Sarah Connelly', loc: 'Limerick', init: 'SC', bg: '#F58A3C' },
  { stars: 5, quote: "Perfect birthday gift. Typed the name, picked the colours, it arrived looking exactly like the preview. Magic.", name: 'Pádraic Walsh', loc: 'Sligo', init: 'PW', bg: '#7C3AED' },
  { stars: 5, quote: "These are SO well made. Solid, heavy, and the studs are perfect. Snapped straight onto a baseplate. 10/10.", name: 'Emma Riordan', loc: 'Waterford', init: 'ER', bg: '#0F766E' },
];

const sliderCards = [
  { img: '/products/luca-letters.jpg', alt: 'Rainbow LUCA 3D brick letters', cat: 'Brick Letters', name: 'Name Letters', price: 'from €7', href: '/products/brick-letters', badge: 'Best Seller' },
  { img: '/products/finn-letters.jpg', alt: 'Blue FINN letters in a nursery', cat: 'Brick Letters', name: 'Nursery Names', price: 'from €7', href: '/products/brick-letters', badge: null },
  { img: '/products/charlie-sign.jpg', alt: 'Charlie door sign on red baseplate', cat: 'Door Sign', name: 'Door / Room Sign', price: 'from €12', href: '/products/door-sign', badge: 'New' },
  { img: '/products/robert-letters.jpg', alt: 'Rainbow ROBERT brick letters', cat: 'Brick Letters', name: 'Rainbow Letters', price: 'from €7', href: '/products/brick-letters', badge: null },
  { img: '/products/luca-letters.jpg', alt: 'Gift-ready brick name letters', cat: 'Brick Letters', name: 'Gift Ready', price: 'from €7', href: '/products/brick-letters', badge: null },
  { img: '/products/charlie-sign.jpg', alt: 'Personalised door sign', cat: 'Door Sign', name: 'Personalised Sign', price: 'from €12', href: '/products/door-sign', badge: null },
];
// Duplicate for seamless loop
const allCards = [...sliderCards, ...sliderCards];
---

<Base
  title="TógBlocks — Build names they'll love forever"
  description="Personalised 3D brick name letters and door signs, handmade in Ireland. Compatible with LEGO®. Type a name, pick colours, we build and post."
  currentPage="/"
  ogImage="/products/luca-letters.jpg"
>

  <!-- ═══════════════════════════════════════════════ HERO ═══ -->
  <section class="home-hero" aria-label="Hero">

    <!-- Background slideshow — images cycle every 4 s -->
    <div class="home-hero__slides" aria-hidden="true" data-hero-slides>
      <div class="hero-slide is-active" style={`background-image:url('/products/luca-letters.jpg')`}></div>
      <div class="hero-slide" style={`background-image:url('/products/finn-letters.jpg')`}></div>
      <div class="hero-slide" style={`background-image:url('/products/robert-letters.jpg')`}></div>
      <div class="hero-slide" style={`background-image:url('/products/charlie-sign.jpg')`}></div>
    </div>
    <div class="home-hero__overlay" aria-hidden="true"></div>

    <!-- Arrow navigation -->
    <button class="hero-arrow hero-arrow--prev" data-hero-prev aria-label="Previous photo">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="hero-arrow hero-arrow--next" data-hero-next aria-label="Next photo">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Dot indicators -->
    <div class="hero-dots" aria-hidden="true" data-hero-dots>
      <button class="hero-dot is-active" data-index="0"></button>
      <button class="hero-dot" data-index="1"></button>
      <button class="hero-dot" data-index="2"></button>
      <button class="hero-dot" data-index="3"></button>
    </div>

    <!-- Content -->
    <div class="home-hero__content wrap">
      <h1>Build names they'll love <em class="accent">forever</em></h1>
      <p class="home-hero__sub">
        Personalised 3D brick letters &amp; door signs — handmade in Ireland, compatible with LEGO®.
      </p>
      <div class="home-hero__ctas">
        <a class="btn btn--cta btn--lg" href="/products">Shop all products</a>
        <a class="btn btn--white-outline btn--lg" href="/builder">
          Start building
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

  </section>

  <!-- ════════════════════════════════════════ STATS ═══ -->
  <section class="stats-band" aria-label="By the numbers">
    <div class="wrap">
      <div class="stats-grid">
        {[
          { num: '600+', label: 'Happy builders' },
          { num: '★ 4.9', label: 'Average rating' },
          { num: '3 days', label: 'Ships in' },
          { num: '100%', label: 'Handmade' },
        ].map((s, i) => (
          <div class="stat-card" data-reveal data-delay={String(i + 1)}>
            <span class="stat-card__num">{s.num}</span>
            <span class="stat-card__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ FEATURE SPLIT — LETTERS ═══ -->
  <section class="feature-split" aria-labelledby="feat1">
    <div class="wrap">
      <div class="feature-split__inner" data-reveal>
        <div class="feature-split__visual">
          <img
            src="/products/finn-letters.jpg"
            alt="Blue 3D brick letters FINN displayed on a white nursery shelf"
            loading="lazy"
            decoding="async"
          />
          <div class="feature-split__visual-badge">
            🏆 Best for nurseries &amp; bedrooms
          </div>
        </div>
        <div class="feature-split__copy">
          <span class="eyebrow">
            <span class="stud-dot" style="color:var(--orange)" aria-hidden="true"></span>
            Our products
          </span>
          <h2 id="feat1" class="product-title">Brick Name Letters</h2>
          <p class="product-subtitle">A keepsake they'll still love at&nbsp;18</p>
          <p>Chunky 3D letters built from genuine compatible bricks — every stud perfect, every colour exactly as you designed it in the builder.</p>
          <ul class="feature-list">
            <li><span class="icon" aria-hidden="true">✓</span> Snaps onto any standard baseplate</li>
            <li><span class="icon" aria-hidden="true">🎨</span> 5 colour themes + per-letter recolour</li>
            <li><span class="icon" aria-hidden="true">📐</span> Small, Medium &amp; Large sizes</li>
            <li><span class="icon" aria-hidden="true">🇮🇪</span> Built by hand in Ireland, ships in 3 days</li>
          </ul>
          <a class="btn btn--cta btn--lg" href="/products/brick-letters">
            Shop Brick Letters →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ FEATURE SPLIT — SIGN ═══ -->
  <section class="feature-split" style="background:#f7f9fc" aria-labelledby="feat2">
    <div class="wrap">
      <div class="feature-split__inner rev" data-reveal>
        <div class="feature-split__visual" style="aspect-ratio:1">
          <img
            src="/products/charlie-sign.jpg"
            alt="Red LEGO baseplate door sign with Charlie in yellow raised letters"
            loading="lazy"
            decoding="async"
          />
          <div class="feature-split__visual-badge">
            🚪 Bedroom doors, lockers, desks
          </div>
        </div>
        <div class="feature-split__copy">
          <span class="eyebrow">
            <span class="stud-dot" style="color:var(--orange)" aria-hidden="true"></span>
            Our products
          </span>
          <h2 id="feat2" class="product-title">Door &amp; Room Signs</h2>
          <p class="product-subtitle">Make their space officially&nbsp;theirs</p>
          <p>A colourful LEGO-compatible baseplate with their name raised in contrasting brick letters — with playful decorative bricks on the edges.</p>
          <ul class="feature-list">
            <li><span class="icon" aria-hidden="true">✓</span> Choose plate colour + text colour</li>
            <li><span class="icon" aria-hidden="true">🧱</span> Decorative edge bricks included</li>
            <li><span class="icon" aria-hidden="true">🔧</span> Fully rearrangeable &amp; rebuild-able</li>
            <li><span class="icon" aria-hidden="true">📦</span> Gift-boxed, ready to give</li>
          </ul>
          <a class="btn btn--cta btn--lg" href="/products/door-sign">
            Shop Door Signs →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ HOW IT WORKS ═══ -->
  <section class="how-section" aria-labelledby="how-heading">
    <div class="wrap">
      <div class="sec-head" data-reveal>
        <span class="eyebrow">
          <span class="stud-dot" style="color:var(--green)" aria-hidden="true"></span>
          Simple process
        </span>
        <h2 id="how-heading">Three steps to a keepsake</h2>
        <p>No design skills. No fiddly tools. If you can type, you can build.</p>
      </div>
      <div class="how-steps">
        {[
          { icon: '⌨️', title: 'Type the name', body: 'Up to 14 letters. A baby\'s name, a nickname, "BOSS" — whatever you fancy.', delay: '1' },
          { icon: '🎨', title: 'Pick your colours', body: 'Choose a theme or tap any single letter to recolour just that one.', delay: '2' },
          { icon: '📦', title: 'We build & post it', body: 'Hand-assembled in Ireland, quality-checked, boxed and sent to your door.', delay: '3' },
        ].map((step, i) => (
          <div class="how-step" data-reveal data-delay={step.delay}>
            <span class="how-step__num" aria-hidden="true">{i + 1}</span>
            <div class="how-step__icon" aria-hidden="true">{step.icon}</div>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ PRODUCT CAROUSEL ═══ -->
  <section class="products-carousel" aria-labelledby="carousel-heading">
    <div class="wrap carousel-head" data-reveal>
      <h2 id="carousel-heading">Our builds</h2>
      <p class="muted">Tap any card to personalise it.</p>
    </div>
    <div class="slider-viewport" aria-label="Product categories">
      <div class="slider-track" data-slider role="list">
        {allCards.map((card) => (
          <a href={card.href} class="slider-card" role="listitem" aria-label={`${card.name} — ${card.price}`}>
            {card.badge && <span class="slider-card__sticker">{card.badge}</span>}
            <div class="slider-card__media">
              <img src={card.img} alt={card.alt} loading="lazy" decoding="async" />
              <div class="slider-card__overlay" aria-hidden="true">
                <span class="btn btn--cta slider-card__cta">Personalise it →</span>
              </div>
            </div>
            <div class="slider-card__body">
              <span class="slider-card__cat">{card.cat}</span>
              <p class="slider-card__name">{card.name}</p>
              <span class="slider-card__price">{card.price}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ PHOTO MOSAIC ═══ -->
  <section class="photo-mosaic-section" aria-labelledby="gallery-heading">
    <div class="wrap">
      <div class="sec-head" data-reveal>
        <span class="eyebrow" style="color:rgba(255,255,255,.7)">In the wild</span>
        <h2 id="gallery-heading">Where they end up</h2>
        <p>Nursery shelves, bedroom doors, birthday tables — every build has a home.</p>
      </div>
    </div>
    <div class="wrap">
      <div class="photo-mosaic" data-reveal>
        <div class="mosaic-img pm-1">
          <img src="/products/luca-letters.jpg" alt="Rainbow LUCA brick letters on a wooden surface" loading="lazy" decoding="async" />
          <span class="mosaic-img__label">Desk &amp; shelf</span>
        </div>
        <div class="mosaic-img pm-2">
          <img src="/products/finn-letters.jpg" alt="Blue FINN letters in a child's bedroom" loading="lazy" decoding="async" />
          <span class="mosaic-img__label">Nursery</span>
        </div>
        <div class="mosaic-img pm-3">
          <img src="/products/charlie-sign.jpg" alt="Charlie personalised door sign" loading="lazy" decoding="async" />
          <span class="mosaic-img__label">Door sign</span>
        </div>
        <div class="mosaic-img pm-4">
          <img src="/products/robert-letters.jpg" alt="Rainbow ROBERT brick letters on a dark shelf" loading="lazy" decoding="async" />
          <span class="mosaic-img__label">Birthday gift</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ TESTIMONIALS ═══ -->
  <section class="testimonials-section" aria-labelledby="reviews-heading">
    <div class="section-label" data-reveal>
      <span class="eyebrow">
        <span class="stud-dot" style="color:var(--orange)" aria-hidden="true"></span>
        Real reviews
      </span>
      <h2 id="reviews-heading">People rather love them</h2>
    </div>

    <div class="reviews-track-wrap">
      <div class="reviews-track" aria-label="Customer reviews">
        {[...reviews, ...reviews].map((r, i) => (
          <article class="review-card" aria-label={`Review by ${r.name}`}>
            <div class="review-card__stars" aria-label={`${r.stars} out of 5 stars`}>
              {'★'.repeat(r.stars)}
            </div>
            <blockquote>"{r.quote}"</blockquote>
            <div class="review-card__by">
              <div class="review-card__avatar" style={`background:${r.bg}`} aria-hidden="true">
                {r.init}
              </div>
              <div>
                <p class="review-card__name">{r.name}</p>
                <p class="review-card__loc">{r.loc}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════ BIG CTA ═══ -->
  <section class="cta-band-full" aria-labelledby="cta-heading">
    <div class="wrap">
      <span class="cta-band-full__eyebrow">Ready to build?</span>
      <h2 id="cta-heading">Their name.<br><em>In bricks.</em></h2>
      <p>Takes two minutes. Arrives in days. Lasts forever.</p>
      <div class="cta-band-full__actions">
        <a class="btn btn--cta btn--lg" href="/builder">Open the builder</a>
        <a class="btn btn--white-outline btn--lg" href="/products">Browse products</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════ NEWSLETTER ═══ -->
  <section class="newsletter-section" aria-labelledby="nl-heading">
    <div class="wrap">
      <div class="newsletter-inner">
        <div>
          <h2 id="nl-heading">Get €5 off your first build</h2>
          <p>The occasional brick-related delight and a welcome discount. No spam, promise.</p>
        </div>
        <div>
          <form class="newsletter-form" data-newsletter>
            <label class="sr-only" for="nl-email">Email address</label>
            <input class="input" id="nl-email" type="email" required placeholder="you@example.ie" />
            <button class="btn btn--cta" type="submit">Send it on</button>
          </form>
          <p data-newsletter-msg hidden></p>
        </div>
      </div>
    </div>
  </section>

</Base>
