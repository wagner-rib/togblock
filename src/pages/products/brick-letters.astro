---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Brick Name Letters — TógBlocks"
  description="Personalised 3D LEGO-compatible brick name letters. Each letter a chunky solid block in your chosen colour. 3D printed in Ireland, ships in 3 days."
  currentPage="/products/brick-letters"
  ogImage="/products/luca-letters.jpg"
>

  <article>
    <!-- ============ BREADCRUMB + HERO ============ -->
    <section class="section-tight">
      <div class="wrap">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Home</a></li>
            <li><a href="/products">Products</a></li>
            <li aria-current="page">Brick Name Letters</li>
          </ol>
        </nav>

        <div class="pdp-hero">
          <!-- Gallery -->
          <div class="pdp-gallery">
            <div class="pdp-main-photo">
              <img
                src="/products/luca-letters.jpg"
                alt="Rainbow 3D brick letters L U C A on wooden surface with LEGO minifigures"
                loading="eager" decoding="async"
                id="main-photo"
              />
            </div>
            <div class="pdp-thumbs">
              <button class="pdp-thumb is-active" data-photo="/products/luca-letters.jpg" aria-label="Main product photo">
                <img src="/products/luca-letters.jpg" alt="" aria-hidden="true" />
              </button>
              <button class="pdp-thumb" data-photo="/products/robert-letters.jpg" aria-label="ROBERT letters photo">
                <img src="/products/robert-letters.jpg" alt="" aria-hidden="true" />
              </button>
              <button class="pdp-thumb" data-photo="/products/finn-letters.jpg" aria-label="FINN letters in blue tones">
                <img src="/products/finn-letters.jpg" alt="" aria-hidden="true" />
              </button>
            </div>
          </div>

          <!-- Info panel -->
          <div class="pdp-info">
            <span class="eyebrow"><span class="stud-dot" style="color:var(--orange)" aria-hidden="true"></span> 3D Printed in Ireland</span>
            <h1 class="pdp-title">Brick Name Letters</h1>
            <div class="pdp-price">
              <span class="price-tag" style="font-size:var(--fs-2xl)">from €7</span>
              <span class="muted" style="font-size:var(--fs-sm)">€7 first letter · €5 each additional</span>
            </div>
            <p class="pdp-desc">
              Chunky 3D letters built from genuine LEGO-compatible bricks. Each letter stands freely on any surface
              — nursery shelf, bedroom desk, cake topper. Tap any letter in the builder to recolour just that one.
            </p>
            <ul class="spec-list">
              <li>
                <span class="si-ico" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                Up to 14 letters per name
              </li>
              <li>
                <span class="si-ico" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                One standard size (~22mm studs)
              </li>
              <li>
                <span class="si-ico" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                7 colour themes or pick individual letter colours
              </li>
              <li>
                <span class="si-ico" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                Clicks onto any standard LEGO® baseplate
              </li>
              <li>
                <span class="si-ico" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                Shipped within 3 working days · free over €40
              </li>
            </ul>
            <a class="btn btn--cta btn--lg btn--block" href="/builder?product=letters" style="margin-top:8px">
              Personalise It
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <p class="muted" style="font-size:var(--fs-xs);margin-top:10px;text-align:center">
              Compatible with LEGO®. TógBlocks is independent and not affiliated with the LEGO Group.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ FEATURES ============ -->
    <section class="section" style="background:var(--offwhite)" aria-labelledby="features-heading">
      <div class="wrap">
        <div class="sec-head">
          <h2 id="features-heading">Why families love them</h2>
        </div>
        <div class="grid grid-3">
          <div class="card" style="text-align:center">
            <div class="feat-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Premium feel</h3>
            <p class="muted">Solid, satisfying weight. These are not toys — they're display pieces that happen to be bricks.</p>
          </div>
          <div class="card" style="text-align:center">
            <div class="feat-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/>
                <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>What you see is what you get</h3>
            <p class="muted">The live preview matches the final product. No surprises when the box arrives.</p>
          </div>
          <div class="card" style="text-align:center">
            <div class="feat-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="currentColor" stroke-width="2"/>
                <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Ready in 3 days</h3>
            <p class="muted">3D printed and posted in Ireland. Most orders arrive within 4–5 days total.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PHOTO GALLERY ============ -->
    <section class="section" aria-labelledby="gallery-heading">
      <div class="wrap">
        <div class="sec-head">
          <h2 id="gallery-heading">See them in the wild</h2>
          <p>Real builds from real customers, photographed in their homes.</p>
        </div>
        <div class="pdp-gallery-grid">
          <div class="pdp-gal-item pdp-gal-item--wide">
            <img src="/products/robert-letters.jpg" alt="Rainbow brick letters ROBERT on a dark shelf with Emmet and Sonic minifigures" loading="lazy" decoding="async" />
          </div>
          <div class="pdp-gal-item">
            <img src="/products/finn-letters.jpg" alt="Blue toned brick letters FINN on a white kids room shelf with minifigures" loading="lazy" decoding="async" />
          </div>
          <div class="pdp-gal-item">
            <img src="/products/luca-letters.jpg" alt="Rainbow brick letters LUCA on wooden surface" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section class="section-tight">
      <div class="wrap center">
        <div class="cta-band">
          <div class="studs-deco" aria-hidden="true"></div>
          <h2 style="margin-bottom:12px">Ready to build?</h2>
          <p style="color:rgba(255,255,255,.85);margin-bottom:24px">Takes less than 2 minutes. We do the rest.</p>
          <a class="btn btn--cta btn--lg" href="/builder?product=letters">Personalise It now <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>
  </article>

</Base>

<style>
.pdp-hero {
  display: grid; grid-template-columns: 1.1fr 1fr;
  gap: clamp(24px, 4vw, 60px); align-items: start;
  padding-top: clamp(16px, 2vw, 24px);
}
.pdp-gallery { display: flex; flex-direction: column; gap: 10px; }
.pdp-main-photo {
  border-radius: var(--radius-lg); overflow: hidden;
  aspect-ratio: 4/3; background: var(--offwhite);
}
.pdp-main-photo img {
  width: 100%; height: 100%; object-fit: cover; display: block;
}
.pdp-thumbs { display: flex; gap: 10px; }
.pdp-thumb {
  width: 80px; height: 60px; border-radius: var(--radius-sm);
  overflow: hidden; border: 2.5px solid transparent; cursor: pointer;
  background: none; padding: 0; flex: none;
  transition: border-color .15s, transform .15s var(--ease-pop);
}
.pdp-thumb:hover { border-color: var(--sage); transform: scale(1.04); }
.pdp-thumb.is-active { border-color: var(--green-deep); }
.pdp-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.pdp-info { display: flex; flex-direction: column; gap: 16px; padding-top: 4px; }
.pdp-title { font-size: var(--fs-3xl); color: var(--ink); margin-top: 6px; }
.pdp-price { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; }
.pdp-desc { color: #555; line-height: 1.65; font-size: var(--fs-base); }

.feat-icon {
  width: 60px; height: 60px; margin: 0 auto 14px;
  background: var(--green-soft); color: var(--green-deep);
  border-radius: var(--radius-md); display: grid; place-items: center;
}

.pdp-gallery-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  gap: clamp(8px, 1.5vw, 16px);
}
.pdp-gal-item {
  border-radius: var(--radius-md); overflow: hidden; aspect-ratio: 4/3;
}
.pdp-gal-item--wide { aspect-ratio: 16/9; }
.pdp-gal-item img { width: 100%; height: 100%; object-fit: cover; display: block; }

@media (max-width: 820px) {
  .pdp-hero { grid-template-columns: 1fr; }
  .pdp-thumbs { flex-wrap: wrap; }
  .pdp-gallery-grid { grid-template-columns: 1fr 1fr; }
  .pdp-gal-item--wide { grid-column: span 2; }
}
@media (max-width: 500px) {
  .pdp-gallery-grid { grid-template-columns: 1fr; }
  .pdp-gal-item--wide { grid-column: span 1; }
}
</style>

<script>
// Thumbnail gallery switcher
document.addEventListener('DOMContentLoaded', () => {
  const mainPhoto = document.getElementById('main-photo') as HTMLImageElement | null;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.pdp-thumb');
  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      const photo = thumb.dataset.photo;
      if (mainPhoto && photo) {
        mainPhoto.src = photo;
        mainPhoto.alt = thumb.getAttribute('aria-label') || '';
      }
      thumbs.forEach(t => t.classList.remove('is-active'));
      thumb.classList.add('is-active');
    });
  });
});
</script>
