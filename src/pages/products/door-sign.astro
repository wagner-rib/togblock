---
import Base from '../../layouts/Base.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Personalised Door & Room Sign",
  "description": "A personalised brick baseplate door sign with your name raised in contrasting brick letters. Compatible with standard building bricks including LEGO®. 3D printed in Ireland, ships in 3 days.",
  "image": "https://togblocks.ie/products/charlie-sign.jpg",
  "brand": { "@type": "Brand", "name": "TógBlocks" },
  "sku": "DOOR-SIGN",
  "offers": {
    "@type": "Offer",
    "url": "https://togblocks.ie/products/door-sign",
    "priceCurrency": "EUR",
    "price": "12.00",
    "priceValidUntil": "2027-12-31",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "TógBlocks" }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "600"
  }
};
---

<Base
  title="Door & Room Sign — TógBlocks"
  description="Personalised brick door signs, compatible with LEGO® and standard building bricks. Your name raised in the centre of a wide baseplate. 3D printed in Ireland, ships in 3 days."
  currentPage="/products/door-sign"
  ogImage="/products/charlie-sign.jpg"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </Fragment>

  <article>
    <!-- ============ BREADCRUMB + HERO ============ -->
    <section class="section-tight">
      <div class="wrap">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Home</a></li>
            <li><a href="/products">Products</a></li>
            <li aria-current="page">Door / Room Sign</li>
          </ol>
        </nav>

        <div class="pdp-hero">
          <!-- Gallery -->
          <div class="pdp-gallery">
            <div class="pdp-main-photo">
              <img
                src="/products/charlie-sign.jpg"
                alt="Red brick baseplate door sign with Charlie in yellow raised letters and decorative bricks"
                loading="eager" decoding="async"
                id="main-photo"
              />
            </div>
            <div class="pdp-thumbs">
              <button class="pdp-thumb is-active" data-photo="/products/charlie-sign.jpg" aria-label="Charlie door sign — red plate, yellow letters">
                <img src="/products/charlie-sign.jpg" alt="" aria-hidden="true" />
              </button>
              <button class="pdp-thumb" data-photo="/products/luca-letters.jpg" aria-label="Brick letters in rainbow colours">
                <img src="/products/luca-letters.jpg" alt="" aria-hidden="true" />
              </button>
            </div>
          </div>

          <!-- Info panel -->
          <div class="pdp-info">
            <span class="eyebrow"><span class="stud-dot" style="color:var(--orange)" aria-hidden="true"></span> 3D Printed in Ireland</span>
            <h1 class="pdp-title">Door / Room Sign</h1>
            <div class="pdp-price">
              <span class="price-tag" style="font-size:var(--fs-2xl)">from €12</span>
              <span class="muted" style="font-size:var(--fs-sm)">€12 base + €2 per letter</span>
            </div>
            <p class="pdp-desc">
              A wide rectangular brick baseplate with the name raised in contrasting brick-font letters in the centre.
              Decorative 2×1 bricks on the edges complete the look. Designed to lean against a door, hang on a wall,
              or sit on a shelf.
            </p>
            <ul class="spec-list">
              <li>
                <span class="si-ico" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                32×12 stud landscape baseplate
              </li>
              <li>
                <span class="si-ico" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                Name centred in 5×7 raised brick font
              </li>
              <li>
                <span class="si-ico" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                6 plate colours · 6 text colours
              </li>
              <li>
                <span class="si-ico" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                Decorative 2×1 bricks on edges included
              </li>
              <li>
                <span class="si-ico" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </span>
                Compatible with all standard LEGO® bricks
              </li>
            </ul>
            <a class="btn btn--cta btn--lg btn--block" href="/builder?product=sign" style="margin-top:8px">
              Personalise It
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <p class="muted" style="font-size:var(--fs-xs);margin-top:10px;text-align:center">
              Compatible with LEGO®. TógBlocks is independent and not affiliated with the LEGO Group.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ FEATURES ============ -->
    <section class="section" style="background:var(--offwhite)" aria-labelledby="features-heading">
      <div class="wrap">
        <div class="sec-head">
          <h2 id="features-heading">Perfect for every door</h2>
        </div>
        <div class="grid grid-3">
          <div class="card" style="text-align:center">
            <div class="feat-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="2"/>
                <path d="M8 12h8M12 8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <h3>Bold &amp; readable</h3>
            <p class="muted">Raised brick letters in a contrasting colour — visible from across the room, even at a glance.</p>
          </div>
          <div class="card" style="text-align:center">
            <div class="feat-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Sturdy baseplate</h3>
            <p class="muted">A single solid brick baseplate, compatible with standard building bricks. Not going anywhere, but the decorative bricks can be swapped any time.</p>
          </div>
          <div class="card" style="text-align:center">
            <div class="feat-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="currentColor" stroke-width="2"/>
                <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Gifted in 3 days</h3>
            <p class="muted">3D printed and posted in Ireland. The perfect last-minute gift that looks anything but.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ GALLERY ============ -->
    <section class="section" aria-labelledby="gallery-heading">
      <div class="wrap">
        <div class="sec-head">
          <h2 id="gallery-heading">How it looks</h2>
        </div>
        <div class="pdp-gallery-grid">
          <div class="pdp-gal-item pdp-gal-item--wide">
            <img src="/products/charlie-sign.jpg" alt="Red brick baseplate door sign with Charlie in yellow raised letters" loading="lazy" decoding="async" />
          </div>
          <div class="pdp-gal-item">
            <img src="/products/finn-letters.jpg" alt="Blue toned brick letters FINN — shows the stud detail" loading="lazy" decoding="async" />
          </div>
          <div class="pdp-gal-item">
            <img src="/products/robert-letters.jpg" alt="Rainbow brick letters ROBERT on a dark shelf" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section class="section-tight">
      <div class="wrap center">
        <div class="cta-band">
          <div class="studs-deco" aria-hidden="true"></div>
          <h2 style="margin-bottom:12px">Claim the door</h2>
          <p style="color:rgba(255,255,255,.85);margin-bottom:24px">Design your sign in 60 seconds. We'll have it built and posted within 3 days.</p>
          <a class="btn btn--cta btn--lg" href="/builder?product=sign">Personalise It now <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>
  </article>

</Base>

<style>
.pdp-hero {
  display: grid; grid-template-columns: 1.1fr 1fr;
  gap: clamp(24px, 4vw, 60px); align-items: start;
  padding-top: clamp(16px, 2vw, 24px);
}
.pdp-gallery { display: flex; flex-direction: column; gap: 10px; }
.pdp-main-photo {
  border-radius: var(--radius-lg); overflow: hidden;
  aspect-ratio: 4/3; background: var(--offwhite);
}
.pdp-main-photo img {
  width: 100%; height: 100%; object-fit: cover; display: block;
}
.pdp-thumbs { display: flex; gap: 10px; }
.pdp-thumb {
  width: 80px; height: 60px; border-radius: var(--radius-sm);
  overflow: hidden; border: 2.5px solid transparent; cursor: pointer;
  background: none; padding: 0; flex: none;
  transition: border-color .15s, transform .15s var(--ease-pop);
}
.pdp-thumb:hover { border-color: var(--sage); transform: scale(1.04); }
.pdp-thumb.is-active { border-color: var(--green-deep); }
.pdp-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.pdp-info { display: flex; flex-direction: column; gap: 16px; padding-top: 4px; }
.pdp-title { font-size: var(--fs-3xl); color: var(--ink); margin-top: 6px; }
.pdp-price { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; }
.pdp-desc { color: #555; line-height: 1.65; font-size: var(--fs-base); }

.feat-icon {
  width: 60px; height: 60px; margin: 0 auto 14px;
  background: var(--green-soft); color: var(--green-deep);
  border-radius: var(--radius-md); display: grid; place-items: center;
}

.pdp-gallery-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  gap: clamp(8px, 1.5vw, 16px);
}
.pdp-gal-item {
  border-radius: var(--radius-md); overflow: hidden; aspect-ratio: 4/3;
}
.pdp-gal-item--wide { aspect-ratio: 16/9; }
.pdp-gal-item img { width: 100%; height: 100%; object-fit: cover; display: block; }

@media (max-width: 820px) {
  .pdp-hero { grid-template-columns: 1fr; }
  .pdp-thumbs { flex-wrap: wrap; }
  .pdp-gallery-grid { grid-template-columns: 1fr 1fr; }
  .pdp-gal-item--wide { grid-column: span 2; }
}
@media (max-width: 500px) {
  .pdp-gallery-grid { grid-template-columns: 1fr; }
  .pdp-gal-item--wide { grid-column: span 1; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const mainPhoto = document.getElementById('main-photo') as HTMLImageElement | null;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.pdp-thumb');
  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      const photo = thumb.dataset.photo;
      if (mainPhoto && photo) {
        mainPhoto.src = photo;
        mainPhoto.alt = thumb.getAttribute('aria-label') || '';
      }
      thumbs.forEach(t => t.classList.remove('is-active'));
      thumb.classList.add('is-active');
    });
  });
});
</script>
