---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAdminUser } from '../../../lib/adminAuth';
import { query } from '../../../lib/db';

const admin = await getAdminUser(Astro.request);
if (!admin) return Astro.redirect('/login?returnTo=/admin/customers');

const q = Astro.url.searchParams.get('q') ?? '';
const params: unknown[] = [];
let where = '';
if (q) {
  params.push(`%${q.toLowerCase()}%`);
  where = `WHERE LOWER(u.name) LIKE $1 OR LOWER(u.email) LIKE $1`;
}

const res = await query<{
  id: number; name: string; email: string; created_at: Date;
  order_count: string; total_spend: string;
}>(`
  SELECT u.id, u.name, u.email, u.created_at,
    COUNT(DISTINCT o.id) AS order_count,
    COALESCE(SUM(o.total) FILTER (WHERE o.status NOT IN ('pending_payment','cancelled','refunded')), 0) AS total_spend
  FROM users u
  LEFT JOIN orders o ON o.user_id = u.id
  ${where}
  GROUP BY u.id
  ORDER BY total_spend DESC
  LIMIT 100
`, params);

function fmt(cents: number | string) { return `€${(Number(cents)/100).toFixed(2)}`; }
function fmtDate(d: Date) { return new Date(d).toLocaleDateString('en-IE', { dateStyle:'medium' }); }
---

<AdminLayout title="Customers" currentPage="customers" admin={admin}>
  <div class="adm-page-hd">
    <div class="adm-page-title">Customers</div>
  </div>

  <div class="adm-card" style="margin-bottom:16px;padding:14px 16px">
    <form method="GET" style="display:flex;gap:10px">
      <input class="adm-input" name="q" value={q} placeholder="Search by name or email…" style="max-width:320px" />
      <button type="submit" class="adm-btn adm-btn--primary">Search</button>
      {q && <a href="/admin/customers" class="adm-btn adm-btn--ghost">Clear</a>}
    </form>
  </div>

  <div class="adm-card">
    <div class="adm-table-wrap">
      <table class="adm-table">
        <thead>
          <tr><th>Name</th><th>Email</th><th>Joined</th><th>Orders</th><th>Total spent</th><th></th></tr>
        </thead>
        <tbody>
          {res.rows.length === 0 ? (
            <tr><td colspan="6"><div class="adm-empty">No customers found.</div></td></tr>
          ) : res.rows.map(c => (
            <tr>
              <td style="font-weight:700">{c.name}</td>
              <td style="color:var(--ink-60)">{c.email}</td>
              <td style="color:var(--ink-60);white-space:nowrap">{fmtDate(c.created_at)}</td>
              <td>{c.order_count}</td>
              <td style="font-weight:700">{fmt(c.total_spend)}</td>
              <td><a href={`/admin/customers/${c.id}`} class="adm-btn adm-btn--ghost adm-btn--sm">View →</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
