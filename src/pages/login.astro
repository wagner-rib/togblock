---
import Base from '../layouts/Base.astro';
import { getTokenFromRequest, getSession } from '../lib/auth';

const token = getTokenFromRequest(Astro.request);
const user  = token ? await getSession(token) : null;
if (user) return Astro.redirect('/account');

const returnTo = Astro.url.searchParams.get('returnTo') ?? '/account';
---

<Base
  title="Sign in — TógBlocks"
  description="Sign in or create your TógBlocks account."
  currentPage="/login"
>
  <div class="auth-wrap">

    <div class="auth-card">

      <a class="auth-brand" href="/" aria-label="TógBlocks home">
        <svg class="auth-brand-icon" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="3" y="3" width="42" height="42" rx="13" fill="#1D4ED8"/>
          <rect x="3" y="3" width="42" height="20" rx="13" fill="white" opacity=".14"/>
          <rect x="3" y="32" width="42" height="13" rx="13" fill="#1e3a8a" opacity=".5"/>
          <g fill="#1e3a8a" opacity=".22">
            <circle cx="17" cy="18.4" r="5.4"/>
            <circle cx="31" cy="18.4" r="5.4"/>
            <circle cx="17" cy="32.4" r="5.4"/>
            <circle cx="31" cy="32.4" r="5.4"/>
          </g>
          <g fill="white">
            <circle cx="17" cy="17" r="5.4"/>
            <circle cx="31" cy="17" r="5.4"/>
            <circle cx="17" cy="31" r="5.4"/>
            <circle cx="31" cy="31" r="5.4"/>
          </g>
        </svg>
        <span class="auth-brand-word">Tóg<em>Blocks</em></span>
      </a>
      <h1 class="auth-title">Welcome back</h1>
      <p class="auth-sub">Sign in to save your basket and order history.</p>

      <!-- Google -->
      <a href={`/api/auth/google?returnTo=${encodeURIComponent(returnTo)}`} class="btn--google btn--google-lg">
        <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Continue with Google
      </a>

      <div class="auth-divider"><span>or use your email</span></div>

      <!-- Tab switch -->
      <div class="auth-tabs">
        <button class="auth-tab active" data-tab="signin">Sign in</button>
        <button class="auth-tab" data-tab="register">Create account</button>
      </div>

      <!-- Sign in form -->
      <form class="auth-form" id="form-signin" data-form="signin">
        <div class="field-row">
          <label class="field-label" for="si-email">Email</label>
          <input class="input" id="si-email" name="email" type="email" required
                 autocomplete="email" placeholder="you@example.ie" />
        </div>
        <div class="field-row">
          <label class="field-label" for="si-password">Password</label>
          <input class="input" id="si-password" name="password" type="password" required
                 autocomplete="current-password" placeholder="••••••••" />
        </div>
        <p class="auth-error" id="si-error" hidden></p>
        <button class="btn btn--cta btn--lg auth-submit" type="submit">
          <span class="auth-btn-label">Sign in</span>
          <span class="co-spinner" hidden></span>
        </button>
      </form>

      <!-- Register form -->
      <form class="auth-form" id="form-register" data-form="register" hidden>
        <div class="field-row">
          <label class="field-label" for="reg-name">Full name</label>
          <input class="input" id="reg-name" name="name" type="text" required
                 autocomplete="name" placeholder="Aoife Murphy" />
        </div>
        <div class="field-row">
          <label class="field-label" for="reg-email">Email</label>
          <input class="input" id="reg-email" name="email" type="email" required
                 autocomplete="email" placeholder="you@example.ie" />
        </div>
        <div class="field-row">
          <label class="field-label" for="reg-password">Password <span style="font-weight:400;color:var(--ink-40)">(min 8 chars)</span></label>
          <input class="input" id="reg-password" name="password" type="password" required
                 autocomplete="new-password" minlength="8" placeholder="••••••••" />
        </div>
        <p class="auth-error" id="reg-error" hidden></p>
        <button class="btn btn--cta btn--lg auth-submit" type="submit">
          <span class="auth-btn-label">Create account</span>
          <span class="co-spinner" hidden></span>
        </button>
      </form>

      <p class="auth-guest">
        Just browsing? <a href={returnTo !== '/account' ? returnTo : '/checkout'}>Continue as guest →</a>
      </p>
    </div>
  </div>
</Base>

<style>
.auth-wrap {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 48px 20px 80px;
  min-height: calc(100vh - var(--header-h) - 200px);
}
.auth-card {
  background: var(--white);
  border: 1.5px solid var(--line);
  border-radius: var(--radius-xl);
  padding: 40px 36px;
  width: 100%;
  max-width: 420px;
  box-shadow: var(--shadow-lg);
}
.auth-brand {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  text-decoration: none;
  margin-bottom: 20px;
}
.auth-brand-icon {
  width: 44px;
  height: 44px;
  flex-shrink: 0;
}
.auth-brand-word {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.6rem;
  color: var(--ink);
  letter-spacing: -.5px;
}
.auth-brand-word em {
  font-style: normal;
  color: #1D4ED8;
}
.auth-title {
  font-family: var(--font-display);
  font-size: var(--fs-xl);
  font-weight: 800;
  color: var(--ink);
  text-align: center;
  margin: 0 0 6px;
}
.auth-sub { text-align: center; color: var(--ink-60); font-size: var(--fs-sm); margin: 0 0 24px; }

.btn--google-lg {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  background: #fff;
  border: 1.5px solid var(--line);
  border-radius: 999px;
  padding: 11px 20px;
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--ink);
  text-decoration: none;
  transition: box-shadow .15s, border-color .15s;
}
.btn--google-lg:hover { box-shadow: 0 2px 12px rgba(0,0,0,.1); border-color: #ddd; }

.auth-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 20px 0;
  color: var(--ink-40);
  font-size: var(--fs-xs);
}
.auth-divider::before,
.auth-divider::after { content: ''; flex: 1; height: 1px; background: var(--line); }

.auth-tabs {
  display: flex;
  background: var(--offwhite);
  border-radius: 999px;
  padding: 3px;
  margin-bottom: 20px;
}
.auth-tab {
  flex: 1;
  padding: 7px;
  border: none;
  background: transparent;
  border-radius: 999px;
  font-family: var(--font-display);
  font-weight: 600;
  font-size: var(--fs-sm);
  color: var(--ink-60);
  cursor: pointer;
  transition: background .15s, color .15s;
}
.auth-tab.active {
  background: var(--white);
  color: var(--ink);
  box-shadow: 0 1px 4px rgba(0,0,0,.1);
}

.auth-form { display: flex; flex-direction: column; gap: 0; }
.auth-error { color: #dc2626; font-size: var(--fs-sm); margin: 0 0 12px; }
.auth-submit { width: 100%; justify-content: center; margin-top: 16px; }

.auth-guest {
  text-align: center;
  font-size: var(--fs-xs);
  color: var(--ink-40);
  margin: 20px 0 0;
}
.auth-guest a { color: var(--green-deep); font-weight: 600; }
</style>

<script define:vars={{ returnTo }}>
const tabs   = document.querySelectorAll('.auth-tab');
const forms  = { signin: document.getElementById('form-signin'), register: document.getElementById('form-register') };

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    tabs.forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const key = tab.dataset.tab;
    Object.entries(forms).forEach(([k, f]) => { f.hidden = k !== key; });
  });
});

async function submitForm(formEl, endpoint, errorId) {
  const spinner  = formEl.querySelector('.co-spinner');
  const label    = formEl.querySelector('.auth-btn-label');
  const errorEl  = document.getElementById(errorId);
  const data     = Object.fromEntries(new FormData(formEl));
  errorEl.hidden = true;
  spinner.hidden = false;
  label.textContent = '…';

  try {
    const res  = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    const body = await res.json();
    if (!res.ok || body.error) throw new Error(body.error || 'Something went wrong');

    // Sync local cart to server before redirect
    try {
      const cart = JSON.parse(localStorage.getItem('togblocks_cart') || '[]');
      if (cart.length) {
        await fetch('/api/cart', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(cart),
        });
      }
    } catch {}

    window.location.href = body.redirect || returnTo;
  } catch (err) {
    errorEl.textContent = err.message;
    errorEl.hidden = false;
    spinner.hidden = true;
    label.textContent = formEl.dataset.form === 'signin' ? 'Sign in' : 'Create account';
  }
}

document.getElementById('form-signin')?.addEventListener('submit', e => {
  e.preventDefault(); submitForm(e.currentTarget, '/api/auth/login', 'si-error');
});
document.getElementById('form-register')?.addEventListener('submit', e => {
  e.preventDefault(); submitForm(e.currentTarget, '/api/auth/register', 'reg-error');
});
</script>
