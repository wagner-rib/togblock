# Google OAuth — from console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe — from dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLIC_KEY=pk_test_...

# Resend — from resend.com > API Keys
RESEND_API_KEY=re_...

# Session secret — run: openssl rand -hex 32
SESSION_SECRET=change_this_to_32_random_hex_chars

# Database
DATABASE_URL=postgresql://togblocks:changeme@localhost:5434/togblocks
